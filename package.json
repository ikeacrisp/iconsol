{
  "name": "iconsol",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "fetch-icons": "node --import tsx scripts/fetch-icons.ts",
    "generate": "node --import tsx scripts/generate-components.ts",
    "clean": "turbo run clean",
    "copy-icons": "node --import tsx scripts/copy-icons-to-public.ts",
    "icons:build": "node --import tsx tools/icons/build.ts"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "agentation": "^3.0.2",
    "svgo": "^4.0.2",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
